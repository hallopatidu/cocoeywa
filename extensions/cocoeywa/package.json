{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "cocoeywa",
    "version": "1.0.0",
    "author": "coco.magic",
    "editor": ">=3.8.7",
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "build": "tsc",
        "watch": "tsc -w"
    },
    "description": "i18n:cocoeywa.description",
    "main": "./dist/main.js",
    "devDependencies": {
        "@cocos/creator-types": "^3.8.7",
        "@types/node": "^18.17.1",
        "typescript": "^5.9.3"
    },
    "contributions": {
        "asset-db": {
            "mount": {
                "path": "./assets",
                "readonly": false
            }
        },
        "menu": [
            {
                "path": "i18n:cocoeywa",
                "label": "i18n:cocoeywa.show_log",
                "message": "show-log"
            }
        ],
        "messages": {
            "show-log": {
                "methods": [
                    "showLog"
                ]
            }
        },
        "scene": {
            "script": "./dist/scene.js"
        }
    }
}